PORT=4000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-me
OWNER_PRIVATE_KEYS=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_PASSWORD_HASH=

# Optional: Google 2FA (TOTP). If set, login and withdraw require a 6-digit code.
# Prefer enabling 2FA via the app (Security page → Enable 2FA, scan QR) so the secret is stored in the DB.
# If you set ADMIN_TOTP_SECRET here, 2FA is required until you remove this line or clear data/db.json "twoFa".
# Locked out? Remove the "twoFa" key from apps/api/data/db.json, or remove ADMIN_TOTP_SECRET below, then restart API.
# ADMIN_TOTP_SECRET=

# Run pm2 restart/flush as this user (e.g. when API runs as root but PM2 is under g7)
# PM2_TARGET_USER=g7
