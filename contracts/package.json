{
  "name": "@evm-trading/contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "deploy:base": "hardhat run scripts/deploy.ts --network base",
    "deploy:bsc": "hardhat run scripts/deploy.ts --network bsc",
    "deploy:bittensor": "hardhat run scripts/deploy.ts --network bittensor-evm",
    "deploy:bsc-testnet": "hardhat run scripts/deploy.ts --network bsc-testnet",
