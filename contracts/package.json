    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@openzeppelin/contracts": "4.9.6",
    "dotenv": "^16.4.5",
    "ethers": "^6.4.0",
    "hardhat": "^2.22.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@layerzerolabs/oapp-evm": "^0.4.1",
    "@metamask/browser-passworder": "^6.0.0",
