# Wallet (required for deploy, setPeer, send)
PRIVATE_KEY=0x...

# RPC URLs (optional; defaults in hardhat.config.ts)
# BASE_RPC_URL=https://mainnet.base.org
# BSC_RPC_URL=https://bsc-dataseed.binance.org
# BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
# BITTENSOR_EVM_RPC_URL=http://185.8.107.85:9944

# Deploy: no extra env (network from --network flag)

# setPeer: run with --network base, bsc, or bittensor-evm
# CONTRACT_ADDRESS=0x...
# PEER_EID=30374 (on Base/BSC) or 30184 (on Bittensor, for Base)
# PEER_ADDRESS=0x...

# send:base-to-bittensor / send:bsc-to-bittensor
# MESSENGER_BSC_ADDRESS=0x...
